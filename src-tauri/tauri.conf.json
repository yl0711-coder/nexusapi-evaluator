{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NexusAPI Evaluator",
  "version": "0.1.0",
  "identifier": "com.yl0711.nexusapi-evaluator",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:5179",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NexusAPI Evaluator",
        "width": 1280,
        "height": 820,
        "minWidth": 1080,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
